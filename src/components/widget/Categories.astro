---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getCategoryTree } from "../../utils/content-utils";
import CategoryTree from "./CategoryTree.svelte";
import WidgetLayout from "./WidgetLayout.astro";

const categoryTree = await getCategoryTree();

const COLLAPSED_HEIGHT = "7.5rem";
const COLLAPSE_THRESHOLD = 5;

const isCollapsed = categoryTree.length >= COLLAPSE_THRESHOLD;

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<WidgetLayout name={i18n(I18nKey.categories)} id="categories" isCollapsed={isCollapsed} collapsedHeight={COLLAPSED_HEIGHT}
                class={className} style={style}
>
    {categoryTree.map((cat) => (
        <div class="category-item" style={{ marginBottom: '0.25rem' }}>
            <a href={cat.url} class="flex items-center justify-between py-1 text-sm hover:text-[var(--primary)] transition-colors">
                <span>{cat.name}</span>
                <span class="text-xs text-black/40 dark:text-white/40">{cat.count}</span>
            </a>
        </div>
    ))}
</WidgetLayout>