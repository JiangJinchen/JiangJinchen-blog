---
import PostCard from "@components/PostCard.astro";
import CategoryTree from "@components/widget/CategoryTree.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	type CategoryTreeNode,
	getCategoryList,
	getCategoryTree,
	getSortedPosts,
} from "@utils/content-utils";
import { getPostUrlBySlug } from "@utils/url-utils";

export async function getStaticPaths() {
	const categories = await getCategoryList();
	return categories.map((cat) => ({
		params: { path: cat.fullPath },
		props: { category: cat },
	}));
}

const { category } = Astro.props;
const posts = await getSortedPosts();
const allCategories = await getCategoryList();
const categoryTree = await getCategoryTree();

// 获取当前分类路径
const currentPath = category.fullPath;

// 从树形结构中找到当前分类及其子分类
function findCategoryNode(
	nodes: CategoryTreeNode[],
	path: string,
): CategoryTreeNode | null {
	for (const node of nodes) {
		if (node.fullPath === path) {
			return node;
		}
		if (node.children && node.children.length > 0) {
			const found = findCategoryNode(node.children, path);
			if (found) return found;
		}
	}
	return null;
}

const currentCategoryNode = findCategoryNode(categoryTree, currentPath);
const directChildren = currentCategoryNode?.children || [];

// 获取当前分类下的文章（包括子分类的文章）
const filteredPosts = posts.filter((post) => {
	const postCategory = post.data.category;
	if (!postCategory) return false;
	return (
		postCategory === currentPath || postCategory.startsWith(`${currentPath}/`)
	);
});

// 构建面包屑
const breadcrumbs = [];
const parts = currentPath.split("/");
let currentPathAcc = "";
for (let i = 0; i < parts.length; i++) {
	currentPathAcc = i === 0 ? parts[i] : `${currentPathAcc}/${parts[i]}`;
	breadcrumbs.push({
		name: parts[i],
		path: currentPathAcc,
		isCurrent: i === parts.length - 1,
	});
}

function getCategoryUrl(catPath: string): string {
	return `/category/${encodeURIComponent(catPath)}/`;
}
---

<MainGridLayout title={category.name} description={`${i18n(I18nKey.category)}: ${category.name}`}>
	<!-- 面包屑导航 -->
	<div class="flex flex-wrap items-center gap-2 mb-6">
		<a href="/" class="text-[var(--primary)] hover:underline">{i18n(I18nKey.home)}</a>
		<span class="text-black/30 dark:text-white/30">/</span>
		{breadcrumbs.map((crumb) => crumb.isCurrent ? (
			<span class="font-medium">{crumb.name}</span>
		) : (
			<span>
				<a href={getCategoryUrl(crumb.path)} class="text-[var(--primary)] hover:underline">
					{crumb.name}
				</a>
				<span class="text-black/30 dark:text-white/30">/</span>
			</span>
		))}
	</div>

	<!-- 如果有子分类，只显示子分类列表 -->
	{directChildren.length > 0 ? (
		<div class="card-base rounded-xl p-6">
			<h3 class="font-bold text-lg mb-4 flex items-center gap-2">
				<span>{i18n(I18nKey.subCategories)}</span>
				<span class="text-sm font-normal text-black/50 dark:text-white/50">
					({directChildren.length})
				</span>
			</h3>
			<CategoryTree categories={directChildren} client:only="svelte" />
		</div>
	) : (
		<!-- 没有子分类，显示文章列表 -->
		<div>
			<h3 class="font-bold text-lg mb-4 flex items-center gap-2">
				<span>{i18n(I18nKey.posts)}</span>
				<span class="text-sm font-normal text-black/50 dark:text-white/50">
					({filteredPosts.length})
				</span>
			</h3>
			{filteredPosts.length > 0 ? (
				<div class="space-y-4">
					{filteredPosts.map((post) => (
						<PostCard
							entry={post}
							title={post.data.title}
							tags={post.data.tags}
							category={post.data.category ?? undefined}
							published={post.data.published}
							updated={post.data.updated}
							url={getPostUrlBySlug(post.slug)}
							image={post.data.image}
							description={post.data.description}
							draft={post.data.draft}
							style=""
						/>
					))}
				</div>
			) : (
				<div class="card-base rounded-xl p-8 text-center">
					<p class="text-black/50 dark:text-white/50">
						{i18n(I18nKey.noPostsInCategory)}
					</p>
				</div>
			)}
		</div>
	)}
</MainGridLayout>
